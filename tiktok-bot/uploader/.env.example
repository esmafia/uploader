# Copy to .env and adjust as needed.

# Used by the CLI login flow (undetected-chromedriver) and by the noVNC
# control server when launching Chromium.
TIKTOK_LOGIN_URL=https://www.tiktok.com/login

# ---- API / scheduler (Docker compose reads these via the environment: blocks,
# but you can also set them here for local non-Docker runs.) ----

# Path to the SQLite file. Defaults to /data/tiktok.db inside containers,
# ./data/tiktok.db for local runs.
# TIKTOK_API_DB_PATH=/data/tiktok.db

# Where the api container reaches the noVNC control server.
# NOVNC_CONTROL_URL=http://novnc:7900

# URL the webapp iframe uses for noVNC. "/novnc/vnc.html" assumes nginx
# proxying; "http://localhost:6080/vnc.html" works for dev without nginx.
# NOVNC_PUBLIC_URL=/novnc/vnc.html

# URL the noVNC control server POSTs cookies to when login completes.
# API_PUBLIC_URL=http://api:8000

# How often the scheduler polls for due jobs (seconds).
# SCHEDULER_POLL_SECONDS=30

# Scheduler worker concurrency. Default 1 (serial) — bumping this requires the
# worker.loop() to spawn workers, which it currently doesn't; leave at 1.
# SCHEDULER_CONCURRENCY=1

# Log level for the scheduler service.
# LOG_LEVEL=INFO
